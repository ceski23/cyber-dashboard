{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string",
			"description": "The schema to verify this document against."
		},
		"title": {
			"type": "string",
			"description": "The title of the dashboard."
		},
		"widgets": {
			"type": "array",
			"items": {
				"anyOf": [
					{
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "A unique identifier for the widget."
							},
							"type": {
								"type": "string",
								"const": "cpu-load",
								"description": "The type of the widget."
							},
							"columns": {
								"default": 3,
								"description": "The number of columns the widget spans.",
								"type": "number",
								"minimum": 1
							},
							"options": {
								"type": "object",
								"properties": {
									"refreshInterval": {
										"default": 5000,
										"description": "Interval (in ms) to refresh CPU data.",
										"type": "number",
										"minimum": 1000
									},
									"showGraph": {
										"default": true,
										"description": "Whether to display the CPU usage graph.",
										"type": "boolean"
									}
								},
								"additionalProperties": false,
								"description": "The configuration options for the widget."
							}
						},
						"required": ["id", "type", "options"],
						"additionalProperties": false
					},
					{
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "A unique identifier for the widget."
							},
							"type": {
								"type": "string",
								"const": "memory-used",
								"description": "The type of the widget."
							},
							"columns": {
								"default": 3,
								"description": "The number of columns the widget spans.",
								"type": "number",
								"minimum": 1
							},
							"options": {
								"type": "object",
								"properties": {
									"refreshInterval": {
										"default": 5000,
										"description": "Interval (in ms) to refresh memory data.",
										"type": "number",
										"minimum": 1000
									},
									"showGraph": {
										"default": true,
										"description": "Whether to display the memory usage graph.",
										"type": "boolean"
									}
								},
								"additionalProperties": false,
								"description": "The configuration options for the widget."
							}
						},
						"required": ["id", "type", "options"],
						"additionalProperties": false
					},
					{
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "A unique identifier for the widget."
							},
							"type": {
								"type": "string",
								"const": "service-link",
								"description": "The type of the widget."
							},
							"columns": {
								"default": 3,
								"description": "The number of columns the widget spans.",
								"type": "number",
								"minimum": 1
							},
							"options": {
								"type": "object",
								"properties": {
									"name": {
										"type": "string",
										"description": "Name of the service to link to."
									},
									"description": {
										"description": "Optional description of the service.",
										"type": "string"
									},
									"icon": {
										"description": "Optional icon URL for the service.",
										"type": "string",
										"format": "uri"
									},
									"url": {
										"type": "string",
										"format": "uri",
										"description": "URL to link to the service."
									},
									"status": {
										"description": "Service status configuration.",
										"type": "object",
										"properties": {
											"provider": {
												"type": "string",
												"description": "Name of the status provider to use for this service. Must match a provider defined in the dashboard configuration."
											},
											"service": {
												"type": "string",
												"description": "Identifier of the service to check status for (depends on the provider)."
											}
										},
										"required": ["provider", "service"],
										"additionalProperties": false
									}
								},
								"required": ["name", "url"],
								"additionalProperties": false,
								"description": "The configuration options for the widget."
							}
						},
						"required": ["id", "type", "options"],
						"additionalProperties": false
					},
					{
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "A unique identifier for the widget."
							},
							"type": {
								"type": "string",
								"const": "open-meteo-weather",
								"description": "The type of the widget."
							},
							"columns": {
								"default": 3,
								"description": "The number of columns the widget spans.",
								"type": "number",
								"minimum": 1
							},
							"options": {
								"type": "object",
								"properties": {
									"location": {
										"anyOf": [
											{
												"type": "string",
												"const": "auto",
												"description": "Automatically determine location."
											},
											{
												"type": "object",
												"properties": {
													"latitude": {
														"type": "number",
														"minimum": -90,
														"maximum": 90,
														"description": "The latitude of the location."
													},
													"longitude": {
														"type": "number",
														"minimum": -180,
														"maximum": 180,
														"description": "The longitude of the location."
													}
												},
												"required": ["latitude", "longitude"]
											}
										]
									}
								},
								"required": ["location"],
								"additionalProperties": false,
								"description": "The configuration options for the widget."
							}
						},
						"required": ["id", "type", "options"],
						"additionalProperties": false
					},
					{
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "A unique identifier for the widget."
							},
							"type": {
								"type": "string",
								"const": "open-meteo-air-quality",
								"description": "The type of the widget."
							},
							"columns": {
								"default": 3,
								"description": "The number of columns the widget spans.",
								"type": "number",
								"minimum": 1
							},
							"options": {
								"type": "object",
								"properties": {
									"location": {
										"anyOf": [
											{
												"type": "string",
												"const": "auto",
												"description": "Automatically determine location."
											},
											{
												"type": "object",
												"properties": {
													"latitude": {
														"type": "number",
														"minimum": -90,
														"maximum": 90,
														"description": "The latitude of the location."
													},
													"longitude": {
														"type": "number",
														"minimum": -180,
														"maximum": 180,
														"description": "The longitude of the location."
													}
												},
												"required": ["latitude", "longitude"]
											}
										]
									}
								},
								"required": ["location"],
								"additionalProperties": false,
								"description": "The configuration options for the widget."
							}
						},
						"required": ["id", "type", "options"],
						"additionalProperties": false
					}
				]
			},
			"description": "The list of widgets to display on the dashboard."
		},
		"statusProviders": {
			"type": "object",
			"propertyNames": {
				"type": "string",
				"description": "The name of the status provider."
			},
			"additionalProperties": {
				"anyOf": [
					{
						"type": "object",
						"properties": {
							"type": {
								"type": "string",
								"const": "docker"
							},
							"refreshInterval": {
								"default": 5000,
								"description": "The interval in milliseconds to refresh the Docker status.",
								"type": "number"
							},
							"connection": {
								"anyOf": [
									{
										"type": "object",
										"properties": {
											"socketPath": {
												"default": "/var/run/docker.sock",
												"description": "The path to the Docker socket.",
												"type": "string"
											}
										},
										"additionalProperties": false
									},
									{
										"type": "object",
										"properties": {
											"host": {
												"type": "string",
												"description": "The Docker host URL."
											},
											"port": {
												"default": 2375,
												"description": "The Docker host port.",
												"type": "number"
											},
											"protocol": {
												"default": "http",
												"description": "The protocol to use when connecting to the Docker host.",
												"type": "string",
												"enum": ["http", "https"]
											},
											"headers": {
												"description": "Optional headers for the Docker connection.",
												"type": "object",
												"propertyNames": {
													"type": "string"
												},
												"additionalProperties": {
													"type": "string"
												}
											}
										},
										"required": ["host"],
										"additionalProperties": false
									}
								]
							}
						},
						"required": ["type", "connection"],
						"additionalProperties": false
					},
					{
						"type": "object",
						"properties": {
							"type": {
								"type": "string",
								"const": "gatus"
							},
							"refreshInterval": {
								"default": 5000,
								"description": "The interval in milliseconds to refresh the Gatus status.",
								"type": "number"
							},
							"connection": {
								"type": "object",
								"properties": {
									"baseUrl": {
										"type": "string",
										"description": "The base URL of the Gatus instance."
									}
								},
								"required": ["baseUrl"],
								"additionalProperties": false
							}
						},
						"required": ["type", "connection"],
						"additionalProperties": false
					},
					{
						"type": "object",
						"properties": {
							"type": {
								"type": "string",
								"const": "ping"
							},
							"refreshInterval": {
								"default": 5000,
								"description": "The interval in milliseconds to refresh the ping status.",
								"type": "number"
							},
							"timeout": {
								"default": 5000,
								"description": "The timeout in milliseconds for each ping request.",
								"type": "number"
							},
							"version": {
								"default": "ipv4",
								"description": "Whether to use IPv4 or IPv6 for pinging.",
								"type": "string",
								"enum": ["ipv4", "ipv6"]
							},
							"services": {
								"type": "object",
								"propertyNames": {
									"type": "string",
									"description": "Service identifier"
								},
								"additionalProperties": {
									"type": "string",
									"description": "The host to ping (IP address or domain name)"
								}
							}
						},
						"required": ["type", "services"],
						"additionalProperties": false
					}
				],
				"description": "Status providers options."
			}
		},
		"units": {
			"default": "metric",
			"description": "The units to use for weather data. If not specified, the default is metric.",
			"anyOf": [
				{
					"type": "string",
					"const": "metric",
					"description": "Use metric units (Celsius, hPa, etc.)."
				},
				{
					"type": "string",
					"const": "imperial",
					"description": "Use imperial units (Fahrenheit, inHg, etc.)."
				}
			]
		}
	},
	"required": ["widgets"],
	"additionalProperties": false
}
