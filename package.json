{
	"name": "cyber-dashboard-v2",
	"private": true,
	"type": "module",
	"imports": {
		"#lib/auth": "./src/lib/auth/index.ts",
		"#lib/auth/*": "./src/lib/auth/*.ts",
		"#lib/config": "./src/lib/config/index.ts",
		"#lib/config/*": "./src/lib/config/*.ts",
		"#lib/utils/*": "./src/lib/utils/*.ts",
		"#widgets": "./src/widgets/index.ts",
		"#widgets/schemas": "./src/widgets/schemas.ts",
		"#components/*": "./src/components/*/index.tsx",
		"#services/location": "./src/services/location.ts",
		"#services/*": "./src/services/*/index.ts",
		"#services/*/schema": "./src/services/*/schema.ts",
		"#theme.css": "./src/theme.css.ts",
		"#global.css": "./src/global.css.ts"
	},
	"scripts": {
		"dev": "bun --bun vite dev --port 3000",
		"build": "bun --bun vite build",
		"start": "bun .output/server/index.mjs",
		"lint": "oxlint --type-aware .",
		"lint:fix": "oxlint --type-aware --fix",
		"format": "oxfmt --write",
		"format:check": "oxfmt --check",
		"typecheck": "tsgo --noEmit",
		"prepare": "husky",
		"generate:schema": "bun ./scripts/generateJsonSchema.ts",
		"docker:build": "docker build -t cyber-dashboard .",
		"docker:run": "docker run --rm -p 3000:3000 -v ./config.jsonc:/app/config.jsonc --env-file .env cyber-dashboard"
	},
	"dependencies": {
		"@base-ui/react": "1.2.0",
		"@fontsource-variable/inter": "5.2.8",
		"@supercharge/promise-pool": "3.2.0",
		"@tanstack/react-devtools": "0.9.6",
		"@tanstack/react-hotkeys": "0.3.1",
		"@tanstack/react-hotkeys-devtools": "0.3.1",
		"@tanstack/react-query": "5.90.21",
		"@tanstack/react-query-devtools": "5.91.3",
		"@tanstack/react-router": "1.166.2",
		"@tanstack/react-router-devtools": "1.166.2",
		"@tanstack/react-router-ssr-query": "1.166.2",
		"@tanstack/react-start": "1.166.2",
		"@tanstack/router-plugin": "1.166.2",
		"@vanilla-extract/css": "1.18.0",
		"@vanilla-extract/dynamic": "2.1.5",
		"@vanilla-extract/recipes": "0.5.7",
		"better-auth": "1.5.2",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"confbox": "0.2.4",
		"cookie": "1.1.1",
		"cookiejs": "2.1.3",
		"date-fns": "4.1.0",
		"defu": "6.1.4",
		"dockerode": "4.0.9",
		"es-toolkit": "1.45.0",
		"ky": "1.14.3",
		"lucide-react": "0.576.0",
		"mnemonist": "0.40.3",
		"modern-css-reset": "1.4.0",
		"nitro": "npm:nitro-nightly@3.0.1-20260227-181935-bfbb207c",
		"openmeteo": "1.2.3",
		"pretty-bytes": "7.1.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-error-boundary": "6.1.1",
		"recharts": "3.7.0",
		"systeminformation": "5.31.2",
		"ts-pattern": "5.9.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@tanstack/devtools-vite": "0.5.2",
		"@types/bun": "1.3.10",
		"@types/dockerode": "4.0.1",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260226.1",
		"@vanilla-extract/vite-plugin": "5.1.4",
		"@vitejs/plugin-react": "5.1.4",
		"husky": "9.1.7",
		"oxfmt": "0.36.0",
		"oxlint": "1.51.0",
		"oxlint-tsgolint": "0.16.0",
		"vite": "8.0.0-beta.16",
		"vite-plugin-circular-dependency": "0.5.0"
	},
	"overrides": {
		"vite": "8.0.0-beta.16"
	},
	"patchedDependencies": {
		"@tanstack/start-client-core@1.166.2": "patches/@tanstack%2Fstart-client-core@1.166.2.patch"
	}
