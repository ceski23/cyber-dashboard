{
	"name": "cyber-dashboard",
	"private": true,
	"type": "module",
	"imports": {
		"#lib/auth": "./src/lib/auth/index.ts",
		"#lib/auth/*": "./src/lib/auth/*.ts",
		"#lib/config": "./src/lib/config/index.ts",
		"#lib/config/*": "./src/lib/config/*.ts",
		"#lib/utils/*": "./src/lib/utils/*.ts",
		"#widgets": "./src/widgets/index.ts",
		"#widgets/schemas": "./src/widgets/schemas.ts",
		"#components/*": "./src/components/*/index.tsx",
		"#services/location": "./src/services/location.ts",
		"#services/*": "./src/services/*/index.ts",
		"#services/*/schema": "./src/services/*/schema.ts",
		"#theme.css": "./src/theme.css.ts",
		"#global.css": "./src/global.css.ts"
	},
	"scripts": {
		"dev": "bun --bun vp dev --port 3000",
		"build": "bun --bun vp build",
		"start": "bun .output/server/index.mjs",
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"format": "vp fmt --write",
		"format:check": "vp fmt --check",
		"typecheck": "tsgo --noEmit",
		"prepare": "vp config",
		"generate:schema": "bun ./scripts/generateJsonSchema.ts",
		"docker:build": "docker build -t cyber-dashboard .",
		"docker:run": "docker run --rm -p 3000:3000 -v ./config.jsonc:/app/config.jsonc --env-file .env cyber-dashboard"
	},
	"dependencies": {
		"@base-ui/react": "1.3.0",
		"@fontsource-variable/inter": "5.2.8",
		"@supercharge/promise-pool": "3.3.0",
		"@tanstack/react-devtools": "0.10.0",
		"@tanstack/react-hotkeys": "0.8.1",
		"@tanstack/react-hotkeys-devtools": "0.6.1",
		"@tanstack/react-query": "5.95.2",
		"@tanstack/react-query-devtools": "5.95.2",
		"@tanstack/react-router": "1.168.5",
		"@tanstack/react-router-devtools": "1.166.11",
		"@tanstack/react-router-ssr-query": "1.166.10",
		"@tanstack/react-start": "1.167.9",
		"@tanstack/router-plugin": "1.167.6",
		"@vanilla-extract/css": "1.20.0",
		"@vanilla-extract/dynamic": "2.1.5",
		"@vanilla-extract/recipes": "0.5.7",
		"cmdk": "1.1.1",
		"confbox": "0.2.4",
		"cookie": "1.1.1",
		"cookiejs": "2.1.4",
		"date-fns": "4.1.0",
		"defu": "6.1.4",
		"dockerode": "4.0.10",
		"es-toolkit": "1.45.1",
		"ky": "1.14.3",
		"lucide-react": "1.7.0",
		"mnemonist": "0.40.3",
		"modern-css-reset": "1.4.0",
		"ms": "4.0.0-nightly.202508271359",
		"nitro": "npm:nitro-nightly@3.0.1-20260227-181935-bfbb207c",
		"openmeteo": "1.2.3",
		"pretty-bytes": "7.1.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-error-boundary": "6.1.1",
		"recharts": "3.8.1",
		"reclassify": "^0.4.1",
		"systeminformation": "5.31.5",
		"ts-pattern": "5.9.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@tanstack/devtools-vite": "0.6.0",
		"@types/bun": "1.3.10",
		"@types/dockerode": "4.0.1",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260226.1",
		"@vanilla-extract/vite-plugin": "5.2.1",
		"@vitejs/plugin-react": "6.0.1",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plugin-circular-dependency": "0.5.0",
		"vite-plus": "0.1.14"
	},
	"overrides": {
		"vite": "npm:@voidzero-dev/vite-plus-core@latest"
	},
	"patchedDependencies": {
		"@tanstack/start-client-core@1.166.2": "patches/@tanstack%2Fstart-client-core@1.166.2.patch"
	},
	"packageManager": "bun@1.3.10"
}
